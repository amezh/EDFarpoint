{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ED Farpoint",
  "version": "0.0.0",
  "identifier": "com.edfarpoint.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ED Farpoint",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "maximizable": true,
        "alwaysOnTop": false,
        "decorations": true,
        "transparent": false
      },
      {
        "label": "overlay",
        "title": "ED Farpoint Overlay",
        "url": "overlay.html",
        "create": false,
        "width": 350,
        "height": 250,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ3MUVGQTlCNTIzNjY1Q0YKUldUUFpUWlNtL29lUnhjL0dSem9LdTM0eXMvVXRhaXVNMC9KcXpBLzR1K1VPblRIQXR6Nkw1UDUK",
      "endpoints": [
        "https://github.com/amezh/EDFarpoint/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": [
      "assets/bio_rules.json"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
